PORT=5000
VITE_API_URL=http://localhost:5000

# Firebase client config used by the React app if you want direct browser reads.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin config used by Express to write inquiries to Firestore.
# Option A: paste the complete service account JSON into FIREBASE_SERVICE_ACCOUNT.
FIREBASE_SERVICE_ACCOUNT=

# Option B: set these individual values instead.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
